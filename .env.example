# Copy to .env and edit before running docker-compose in production.

# PostgreSQL password (used by both the db and api services).
DB_PASSWORD=change-this-db-password

# Backend secret key (entropy for sessions). Use a long random value.
SECRET_KEY=change-this-to-a-long-random-string

# Session cookie Secure flag. Keep false only for plain-HTTP local testing on
# :8080; set to true once the app is served over HTTPS.
COOKIE_SECURE=false

# Host port the web UI is published on.
WEB_PORT=8080

# Session lifetime (hours).
SESSION_TTL_HOURS=12
