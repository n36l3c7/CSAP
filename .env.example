# Copy to .env and edit before running docker-compose in production.

# PostgreSQL password (used by both the db and api services). Any character
# is fine; only if it contains # or $ wrap the value in single quotes.
DB_PASSWORD=change-this-db-password

# Backend secret key (entropy for sessions). Use a long random value.
SECRET_KEY=change-this-to-a-long-random-string

# Session cookie Secure flag. Keep false while users may still reach the app
# over plain HTTP on :8080; set to true (recommended) once everyone uses the
# HTTPS port.
COOKIE_SECURE=false

# Host port the web UI is published on (plain HTTP).
WEB_PORT=8080

# Host port for HTTPS. A self-signed certificate is generated on first start
# unless you mount your own into the web-certs volume (see the README).
WEB_TLS_PORT=8443

# Hostname embedded in the auto-generated certificate (CN + SAN). Set it to
# whatever users type in the browser, e.g. nik.example.internal.
TLS_HOSTNAME=localhost

# Session lifetime (hours).
SESSION_TTL_HOURS=12
