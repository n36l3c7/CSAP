# CSAP backend environment configuration.
# Copy to `.env` and adjust for your environment.

# Database connection string.
# Dev default (used if unset): a local SQLite file — no external DB required.
#   sqlite:///./csap.db
# Production example (PostgreSQL via psycopg 3):
#   postgresql+psycopg://csap:CHANGE_ME@localhost/csap
# NOTE: in a URL the password must be percent-encoded. Alternative that needs
# no encoding: leave DATABASE_URL unset and set the DB_* parts instead
# (DB_PASSWORD required; DB_USER/DB_HOST/DB_PORT/DB_NAME optional) — the app
# escapes them itself.
DATABASE_URL=sqlite:///./csap.db

# Secret key used for signing/entropy. Set a long random value in production.
SECRET_KEY=change-me-to-a-long-random-string

# Whether the session cookie is marked Secure (HTTPS-only).
# Set to false for plain-HTTP local development; keep true in production.
COOKIE_SECURE=true

# Session lifetime in hours (default 12).
SESSION_TTL_HOURS=12
